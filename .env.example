# ─── Databáza ────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=secret
DB_DATABASE=johnsgarage
DB_USERNAME=johnsgarage
DB_PASSWORD=secret

# ─── Laravel (vygenerovať: docker compose exec backend php artisan key:generate --show) ──
APP_KEY=base64:REPLACE_WITH_GENERATED_KEY

# ─── Produkcia: Let's Encrypt (email pre upozornenia o certifikáte) ──────────
ACME_EMAIL=your@email.com

# ─── Produkcia: SendGrid ──────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.replace_with_real_key
